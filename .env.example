# Copy to .env locally — never commit .env
# Vercel: add VITE_* in Project → Settings → Environment Variables
# Render: add backend keys in the service dashboard

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_API_URL=https://your-service.onrender.com

VIRUSTOTAL_API_KEY=your_virustotal_key
ALLOWED_ORIGINS=https://your-app.vercel.app

# Phone OTP — MSG91 (India) or Twilio
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_otp_template_id
MSG91_SENDER_ID=AEGISAI
OTP_DEV_MODE=false

# Optional Twilio instead of MSG91
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
